# =====================================================
# ENVIRONMENT CONFIGURATION TEMPLATE
# Copy this file to ".env" and fill in real values.
# NEVER commit the real ".env" file — it is git-ignored.
# =====================================================

# Active environment: qa | staging | prod
ENV=qa

# -------- QA ENVIRONMENT --------
QA_BASE_URL=https://www.aci.aspdotnetstorefront.cambrooke.com/aci_oms_qa/account/signin?returnurl=%2Faci_oms_qa%2F
QA_EMAIL=
QA_PASSWORD=

# -------- STAGING ENVIRONMENT (example placeholders) --------
STAGING_BASE_URL=https://staging.example.com/account/signin
STAGING_EMAIL=
STAGING_PASSWORD=

# -------- PRODUCTION ENVIRONMENT (example placeholders) --------
PROD_BASE_URL=https://www.example.com/account/signin
PROD_EMAIL=
PROD_PASSWORD=

# -------- TEST DATA --------
SEARCH_CUSTOMER_NAME=Hiba
SEARCH_PRODUCT_1=Apple
SEARCH_PRODUCT_1_QTY=6
SEARCH_PRODUCT_2=Aproten
SEARCH_PRODUCT_2_QTY=7

# -------- EXECUTION SETTINGS --------
BROWSER=chromium
HEADLESS=true
DEFAULT_TIMEOUT=30000
ACTION_TIMEOUT=15000
NAVIGATION_TIMEOUT=30000
RETRY_COUNT=1
SLOW_MO=0

# -------- LOGGING --------
LOG_LEVEL=info
